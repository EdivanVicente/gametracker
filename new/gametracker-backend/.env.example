# Renomeie este arquivo para ".env" e preencha com valores reais

# Gere uma chave forte, ex: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-esta-chave-em-producao

# Deixe como está para desenvolvimento (SQLite) ou aponte para o Postgres em produção
DATABASE_URL=sqlite:///./gametracker.db

# Obtenha em https://rawg.io/apidocs
RAWG_API_KEY=

# Obtenha no Google Cloud Console (YouTube Data API v3)
YOUTUBE_API_KEY=
